# Copy to .env (gitignored) before running smoke.sh / docker compose.
#   cp doris-duckbridge/compose/.env.example doris-duckbridge/compose/.env
#
# The Quack RPC token: the duckdb-quack server binds with it, and CREATE CATALOG passes the
# same value so the connector can authenticate. Use any non-empty string for local dev; do
# NOT commit a real token.
QUACK_TOKEN=duckbridge-doris-token

# BE image platform. Default (unset) is linux/amd64 (see docker-compose.yml). On Apple
# Silicon uncomment:
# DORIS_BE_PLATFORM=linux/arm64
